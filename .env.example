# Mặc định cho Docker Compose profile live-capture.
CAPTURE_INTERFACE=eth0
CAPTURE_DURATION=60
CAPTURE_FILTER="arp or udp port 67 or udp port 68"

# PostgreSQL demo. App sẽ ghi database khi các biến PG* này tồn tại.
PGHOST=localhost
PGPORT=5432
PGDATABASE=asset_discovery
PGUSER=postgres
PGPASSWORD=123456
