# ============================================================
# .env.example – Template cho file cấu hình môi trường
# ============================================================
#
# Cách sử dụng:
#   cp .env.example .env
#   # Chỉnh giá trị cho phù hợp, sau đó:
#   docker compose up -d
# ============================================================

# --- Capture settings ---
CAPTURE_INTERFACE=eth0
CAPTURE_MODE=timed
CAPTURE_DURATION=60
CAPTURE_IDLE_TIMEOUT=
CAPTURE_MAX_ASSETS=
CAPTURE_FILTER="arp or udp port 67 or udp port 68"

# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=asset_discovery
PGUSER=postgres
PGPASSWORD=changeme
PGSSLMODE=disable

# --- Docker Compose settings ---
COMPOSE_PROJECT_NAME=asset-discovery
POSTGRES_HOST_PORT=5432
