# Defaults for the Docker Compose live-capture profile.
CAPTURE_INTERFACE=eth0
CAPTURE_DURATION=60
CAPTURE_FILTER="arp or udp port 67 or udp port 68"

# PostgreSQL demo. The app writes to the database when these PG* variables exist.
PGHOST=localhost
PGPORT=5432
PGDATABASE=asset_discovery
PGUSER=postgres
PGPASSWORD=123456
