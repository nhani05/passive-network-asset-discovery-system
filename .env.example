# ============================================================
# .env.example – Template cho file cấu hình môi trường
# ============================================================
#
# Cách sử dụng:
#   DEV:  cp .env.example .env.dev   → chỉnh PGHOST=db, PGSSLMODE=disable
#   PROD: cp .env.example .env.prod  → chỉnh PGHOST=<supabase_host>, PGSSLMODE=require
#
# Chạy:
#   DEV:  docker compose -f docker-compose.yml -f docker-compose.dev.yml  --env-file .env.dev  up -d
#   PROD: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# --- Capture settings ---
CAPTURE_INTERFACE=eth0
CAPTURE_MODE=timed
CAPTURE_DURATION=60
CAPTURE_IDLE_TIMEOUT=
CAPTURE_MAX_ASSETS=
CAPTURE_FILTER="arp or udp port 67 or udp port 68"

# --- PostgreSQL ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=asset_discovery
PGUSER=postgres
PGPASSWORD=changeme
PGSSLMODE=disable

# --- Docker Compose settings ---
COMPOSE_PROJECT_NAME=asset-discovery
POSTGRES_HOST_PORT=5432
